{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://isla.local/schemas/pmx_physics_metadata.schema.json",
  "title": "PMX Physics Metadata Sidecar",
  "type": "object",
  "required": [
    "schema_version",
    "converter",
    "colliders",
    "constraints",
    "collision_layers"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "converter": {
      "type": "object",
      "required": [
        "name",
        "version",
        "command",
        "timestamp_utc"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "minLength": 1
        },
        "command": {
          "type": "string",
          "minLength": 1
        },
        "timestamp_utc": {
          "type": "string",
          "format": "date-time"
        }
      },
      "additionalProperties": true
    },
    "collision_layers": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "index",
          "name"
        ],
        "properties": {
          "index": {
            "type": "integer",
            "minimum": 0,
            "maximum": 31
          },
          "name": {
            "type": "string",
            "minLength": 1
          }
        },
        "additionalProperties": true
      }
    },
    "colliders": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/collider"
      }
    },
    "constraints": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/constraint"
      }
    }
  },
  "$defs": {
    "vec3": {
      "type": "array",
      "items": {
        "type": "number"
      },
      "minItems": 3,
      "maxItems": 3
    },
    "collider": {
      "type": "object",
      "required": [
        "id",
        "bone_name",
        "shape",
        "offset",
        "rotation_euler_deg",
        "is_trigger",
        "layer",
        "mask"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "bone_name": {
          "type": "string",
          "minLength": 1
        },
        "shape": {
          "type": "string",
          "enum": [
            "sphere",
            "capsule",
            "box"
          ]
        },
        "offset": {
          "$ref": "#/$defs/vec3"
        },
        "rotation_euler_deg": {
          "$ref": "#/$defs/vec3"
        },
        "is_trigger": {
          "type": "boolean"
        },
        "layer": {
          "type": "integer",
          "minimum": 0,
          "maximum": 31
        },
        "mask": {
          "type": "integer",
          "minimum": 0,
          "maximum": 4294967295
        },
        "radius": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "height": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "size": {
          "$ref": "#/$defs/vec3"
        },
        "extensions": {
          "type": "object"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "shape": {
                "const": "sphere"
              }
            }
          },
          "then": {
            "required": [
              "radius"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "shape": {
                "const": "capsule"
              }
            }
          },
          "then": {
            "required": [
              "radius",
              "height"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "shape": {
                "const": "box"
              }
            }
          },
          "then": {
            "required": [
              "size"
            ]
          }
        }
      ],
      "additionalProperties": true
    },
    "constraint": {
      "type": "object",
      "required": [
        "id",
        "bone_a_name",
        "bone_b_name",
        "type"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "bone_a_name": {
          "type": "string",
          "minLength": 1
        },
        "bone_b_name": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "type": "string",
          "enum": [
            "fixed",
            "hinge",
            "cone_twist"
          ]
        },
        "limit": {
          "type": "object"
        },
        "extensions": {
          "type": "object"
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
